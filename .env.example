NODE_ENV=development
PORT=4000
APP_NAME=scalable-ecommerce
API_PREFIX=/api/v1
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
GOOGLE_CLIENT_IDS=web-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com,ios-client-id.apps.googleusercontent.com
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
BUSINESS_STATE=KARNATAKA
GSTIN_MARKETPLACE=
REFERRAL_REFERRER_BONUS=100
REFERRAL_REFEREE_BONUS=50
MAX_WALLET_USAGE_PER_ORDER_PERCENT=30
SEQUELIZE_LOGGING=false
SOCKET_CORS_ORIGIN=*
MONGO_URI=mongodb://mongo:27017/ecommerce
POSTGRES_URL=postgresql://postgres:1234@localhost:5432/ecommerce
REDIS_URL=redis://redis:6379
ELASTICSEARCH_NODE=http://elasticsearch:9200
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=key
CLOUDINARY_API_SECRET=secret
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
DEFAULT_FROM_EMAIL=no-reply@example.com
ENABLE_CRON=true
